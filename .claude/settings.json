{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep",

      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm install -D:*)",
      "Bash(npm ci:*)",
      "Bash(npx tsx scripts/:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",

      "Bash(vercel:*)",
      "Bash(gh:*)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git remote:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",

      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(sleep:*)",
      "Bash(rm scripts/_:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -f:*)",
      "Bash(taskkill //F:*)",
      "Bash(taskkill /F:*)",
      "Bash(npm uninstall:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(taskkill:*)",
      "Bash(git reset:*)",
      "Bash(supabase:*)"
    ]
  }
}
